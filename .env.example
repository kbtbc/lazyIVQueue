# Logging
LOG_LEVEL="INFO"
LOG_FILE="False"

# LazyIVQueue Server (webhook receiver + admin API)
LAZYIVQUEUE_HOST=0.0.0.0
LAZYIVQUEUE_PORT=7070

# Max accepted request body size in bytes (default 10 MiB). Raise this if
# large census webhook batches are being rejected with "Content Too Large".
LAZYIVQUEUE_MAX_BODY_SIZE=10485760

# Dragonite Scout API
DRAGONITE_API_BASE_URL=http://127.0.0.1:7272
DRAGONITE_API_USERNAME=
DRAGONITE_API_PASSWORD=
DRAGONITE_API_KEY=
DRAGONITE_BEARER_KEY=

# Auto Rarity Queuer
AUTO_RARITY=FALSE

# Koji Geofence API
# Use either KOJI_URL (full base URL) or KOJI_IP/KOJI_PORT
# GEOFENCE_FILE_PATH=./geofence.json  # optionally read from a geofence file.
FILTER_WITH_KOJI=TRUE
KOJI_URL=
KOJI_IP=127.0.0.1
KOJI_PORT=8080
KOJI_TOKEN=your_bearer_token
KOJI_PROJECT_NAME=your_project_name

# Security
# Comma-separated list of allowed IPs for webhook endpoint
ALLOWED_IPS=127.0.0.1
# Header authentication in format "HeaderName: Value"
HEADERS=
